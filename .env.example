# ============================================
# Beb Fragrance - Environment Variables
# ============================================
# Bu faylni .env.local ga nusxalang va qiymatlarni to'ldiring
# cp .env.example .env.local
# ============================================

# ============================================
# Database (Neon PostgreSQL)
# ============================================
# Neon Dashboard > Project > Connection Details
# DATABASE_URL odatda app runtime uchun pooler string bo'ladi.
# DIRECT_URL esa migratsiya uchun direct string bo'lishi tavsiya etiladi.
DATABASE_URL="postgresql://neondb_owner:[YOUR-PASSWORD]@ep-example-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:[YOUR-PASSWORD]@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ============================================
# NextAuth.js v5
# ============================================
# Mahalliy development uchun
NEXTAUTH_URL="http://localhost:3000"
# Kamida 32 belgili tasodifiy string (openssl rand -base64 32)
NEXTAUTH_SECRET="your-secret-key-minimum-32-characters-here"
# Vercel production uchun AUTH_SECRET ishlatsangiz ham bo'ladi
AUTH_SECRET="your-secret-key-minimum-32-characters-here"

# ============================================
# Google OAuth (Google Cloud Console)
# ============================================
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your-google-client-secret"
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED="false"

# ============================================
# Stripe (To'lov Tizimi)
# ============================================
# https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key"
STRIPE_SECRET_KEY="sk_test_your-secret-key"
# https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ============================================
# UploadThing (Rasm Yuklash)
# ============================================
# https://uploadthing.com/dashboard
UPLOADTHING_TOKEN="ut_your_token"
UPLOADTHING_SECRET="sk_live_your_secret"
UPLOADTHING_APP_ID="your_app_id"

# ============================================
# Resend (Email Xizmati)
# ============================================
# https://resend.com/api-keys
RESEND_API_KEY="re_your-resend-api-key"
EMAIL_FROM="noreply@bebfragrance.com"

# ============================================
# Site URL
# ============================================
# Development: http://localhost:3000
# Production: https://yourdomain.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ============================================
# Seeded Admin Account
# ============================================
# Bu qiymatlar faqat local seed uchun.
ADMIN_EMAIL="admin@bebfragrance.com"
ADMIN_PASSWORD="Admin12345!"

# ============================================
# Local Demo / Fallback Mode
# ============================================
# true bo'lsa, DB ulanmasa ham mock data bilan app ishlaydi
FORCE_MOCK_DATA="false"
